{
  "name": "cursor-agent",
  "version": "0.1.0",
  "description": "Local-first personal agent powered by Cursor SDK (Hermes-inspired).",
  "type": "module",
  "bin": {
    "csagent": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "doctor": "tsx src/cli.ts doctor",
    "run:agent": "tsx src/cli.ts run",
    "chat": "tsx src/cli.ts chat",
    "sessions": "tsx src/cli.ts sessions",
    "resume": "tsx src/cli.ts resume",
    "config": "tsx src/cli.ts config",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "accept": "tsx --test test/acceptance.test.ts",
    "smoke": "bash scripts/smoke.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "ISC",
  "dependencies": {
    "@cursor/sdk": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
