{
  "name": "cursor-agent",
  "version": "0.2.0",
  "description": "Local-first personal agent powered by Cursor SDK (Hermes-inspired).",
  "type": "module",
  "bin": {
    "csagent": "scripts/csagent.mjs"
  },
  "files": [
    "dist",
    "scripts/csagent.mjs",
    "OPS.md",
    "REFERENCE.md",
    "deploy",
    "skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "doctor": "tsx src/cli.ts doctor",
    "run:agent": "tsx src/cli.ts run",
    "chat": "tsx src/cli.ts chat",
    "tui": "tsx src/cli.ts tui",
    "sessions": "tsx src/cli.ts sessions",
    "resume": "tsx src/cli.ts resume",
    "config": "tsx src/cli.ts config",
    "skills": "tsx src/cli.ts skills",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "accept": "tsx --test test/acceptance.test.ts",
    "eval": "tsx src/cli.ts eval run",
    "smoke": "bash scripts/smoke.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "ISC",
  "dependencies": {
    "@cursor/sdk": "^1.0.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "pg": "^8.21.0",
    "puppeteer": "^24.31.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.3.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.29",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
