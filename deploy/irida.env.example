#!/usr/bin/env bash
# irida home (Hermes-style). Copy to ~/.irida/irida.env — or run deploy/setup-home.sh.
# Loaded automatically by irida CLI/TUI/MCP (see src/loadEnv.ts). Optional repo .env overrides unset keys.
export IRIDA_HOME="$HOME/.irida"
export IRIDA_ROOT="$IRIDA_HOME/irida"
# Runtime state: $IRIDA_HOME/.agent/ (credentials, gateway, cron, sqlite, memory)
# Logs: $IRIDA_HOME/logs/
# Store: omit IRIDA_DATABASE_URL for SQLite (Variant 1 in README).
# Variant 2 (Postgres): uncomment the line below after `docker compose … up -d`.
# export IRIDA_DATABASE_URL="postgresql://irida:irida@127.0.0.1:5435/irida_memory"
# Optional overrides:
# export CURSOR_API_KEY=
# export TELEGRAM_BOT_TOKEN=
# export IRIDA_LOG=1
# export IRIDA_LOG_VERBOSE=1
