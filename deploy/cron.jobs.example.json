{
  "version": 1,
  "jobs": [
    {
      "id": "tparser-bi-hourly-digest",
      "cron": "0 */2 * * *",
      "cwd": "/path/to/TParser",
      "skills": [
        "memory-ops"
      ],
      "memoryFactsSubject": "seen_post",
      "memoryFactsLimit": 50,
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      },
      "promptFile": "deploy/prompts/tparser-bi-hourly.prompt.txt"
    },
    {
      "id": "happyin-kb-weekly",
      "cron": "0 3 * * 0",
      "enabled": false,
      "yesIUnderstand": true,
      "promptFile": "deploy/prompts/kb-import-weekly.prompt.txt"
    }
  ]
}
