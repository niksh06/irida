{
  "version": 1,
  "jobs": [
    {
      "id": "tparser-daily-digest",
      "cron": "59 23 * * *",
      "graceMinutes": 480,
      "cwd": "/path/to/TParser",
      "skills": ["memory-ops", "browser-ops"],
      "topicDelegates": true,
      "topicWindowHours": 24,
      "topicPromptFile": "deploy/prompts/tparser-daily-topic.prompt.txt",
      "synthesizePromptFile": "deploy/prompts/tparser-daily-synthesize.prompt.txt",
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      }
    },
    {
      "id": "reddit-rss-fetch",
      "cron": "58 23 * * *",
      "enabled": false,
      "graceMinutes": 480,
      "catchUp": "skip",
      "script": "deploy/scripts/reddit-rss-fetch.sh"
    },
    {
      "id": "reddit-digest-daily",
      "cron": "59 23 * * *",
      "enabled": false,
      "graceMinutes": 480,
      "contextFrom": "reddit-rss-fetch",
      "skills": ["memory-ops"],
      "promptFile": "deploy/prompts/reddit-daily-digest.prompt.txt",
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      }
    },
    {
      "id": "tparser-bi-hourly-digest",
      "cron": "0 */2 * * *",
      "cwd": "/path/to/TParser",
      "skills": ["memory-ops"],
      "promptFile": "deploy/prompts/tparser-bi-hourly.prompt.txt",
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      }
    },
    {
      "id": "memory-curator-weekly",
      "cron": "0 4 * * 0",
      "skills": ["memory-ops"],
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      },
      "promptFile": "deploy/prompts/memory-curator-weekly.prompt.txt"
    },
    {
      "id": "memory-audit-weekly",
      "cron": "30 5 * * 0",
      "builtin": "memory-audit",
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      }
    },
    {
      "id": "session-export-daily",
      "cron": "0 23 * * *",
      "enabled": false,
      "builtin": "session-export"
    },
    {
      "id": "session-ingest-daily",
      "cron": "30 23 * * *",
      "enabled": false,
      "builtin": "session-ingest"
    },
    {
      "id": "cursor-mine-daily",
      "cron": "15 0 * * *",
      "enabled": false,
      "builtin": "cursor-mine"
    },
    {
      "id": "cursor-distill-backfill-queue",
      "cron": "0 8 * * *",
      "enabled": false,
      "builtin": "cursor-distill-backfill-queue"
    },
    {
      "id": "cursor-lesson-backfill",
      "cron": "5 8 * * *",
      "enabled": false,
      "contextFrom": "cursor-distill-backfill-queue",
      "skills": ["memory-ops", "cursor-lesson-ops"],
      "promptFile": "deploy/prompts/cursor-lesson-backfill.prompt.txt"
    },
    {
      "id": "cursor-distill-queue-weekly",
      "cron": "0 7 * * 1",
      "enabled": false,
      "builtin": "cursor-distill-queue"
    },
    {
      "id": "cursor-lesson-weekly",
      "cron": "0 7 * * 1",
      "enabled": false,
      "contextFrom": "cursor-distill-queue-weekly",
      "skills": ["memory-ops", "cursor-lesson-ops"],
      "promptFile": "deploy/prompts/cursor-lesson-weekly.prompt.txt"
    },
    {
      "id": "introspection-weekly",
      "cron": "0 6 * * 1",
      "enabled": false,
      "skills": ["memory-ops", "introspection-ops"],
      "promptFile": "deploy/prompts/introspection-weekly.prompt.txt",
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      }
    },
    {
      "id": "watchdog",
      "cron": "*/30 * * * *",
      "enabled": false,
      "catchUp": "skip",
      "script": "deploy/scripts/csagent-watchdog.sh",
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      }
    },
    {
      "id": "pipeline-source",
      "cron": "0 7 * * *",
      "enabled": false,
      "script": "deploy/scripts/pipeline-echo.sh"
    },
    {
      "id": "pipeline-synth",
      "cron": "5 7 * * *",
      "enabled": false,
      "contextFrom": "pipeline-source",
      "promptFile": "deploy/prompts/pipeline-synth.prompt.txt",
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      }
    }
  ]
}
