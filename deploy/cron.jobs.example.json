{
  "version": 1,
  "jobs": [
    {
      "id": "tparser-daily-digest",
      "cron": "59 23 * * *",
      "cwd": "/path/to/TParser",
      "skills": ["memory-ops", "browser-ops"],
      "memoryFactsSubject": "seen_post",
      "memoryFactsLimit": 200,
      "topicDelegates": true,
      "topicWindowHours": 24,
      "topicPromptFile": "deploy/prompts/tparser-daily-topic.prompt.txt",
      "synthesizePromptFile": "deploy/prompts/tparser-daily-synthesize.prompt.txt",
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      }
    },
    {
      "id": "happyin-kb-weekly",
      "cron": "0 3 * * 0",
      "enabled": false,
      "yesIUnderstand": true,
      "promptFile": "deploy/prompts/kb-import-weekly.prompt.txt"
    },
    {
      "id": "memory-curator-weekly",
      "cron": "0 4 * * 0",
      "skills": ["memory-ops"],
      "notify": {
        "chatId": "YOUR_CHAT_ID",
        "telegram": true
      },
      "promptFile": "deploy/prompts/memory-curator-weekly.prompt.txt"
    }
  ]
}
