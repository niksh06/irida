#!/usr/bin/env bash
# csagent home (Hermes-style). Copy to ~/.csagent/csagent.env — or run deploy/setup-home.sh.
# Loaded automatically by csagent CLI/TUI/MCP (see src/loadEnv.ts). Optional repo .env overrides unset keys.
export CSAGENT_HOME="$HOME/.csagent"
export CSAGENT_ROOT="$CSAGENT_HOME/csagent"
# Runtime state: $CSAGENT_HOME/.agent/ (credentials, gateway, cron, sqlite, memory)
# Logs: $CSAGENT_HOME/logs/
# Hybrid store (Phase 1–2): unset = sqlite; set = Postgres sessions/runs + memory_notes
export CSAGENT_DATABASE_URL="postgresql://csagent:csagent@127.0.0.1:5435/csagent"
# Optional overrides:
# export CURSOR_API_KEY=
# export TELEGRAM_BOT_TOKEN=
# export CSAGENT_LOG=1
# export CSAGENT_LOG_VERBOSE=1
