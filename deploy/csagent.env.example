#!/usr/bin/env bash
# csagent home (Hermes-style). Copy to ~/.csagent/csagent.env — or run deploy/setup-home.sh.
export CSAGENT_HOME="$HOME/.csagent"
export CSAGENT_ROOT="$CSAGENT_HOME/csagent"
# Runtime state: $CSAGENT_HOME/.agent/ (credentials, gateway, cron, sqlite, memory)
# Logs: $CSAGENT_HOME/logs/
# Optional overrides:
# export CURSOR_API_KEY=
# export TELEGRAM_BOT_TOKEN=
