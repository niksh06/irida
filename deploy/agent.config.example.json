{
  "model": "composer-2.5",
  "runtime": "local",
  "memory": {
    "mcp": true,
    "embeddings": {
      "enabled": false,
      "url": "http://127.0.0.1:11434",
      "model": "nomic-embed-text"
    },
    "autoRag": {
      "enabled": false,
      "limit": 2,
      "semantic": false,
      "maxChars": 4000,
      "wings": ["default"]
    }
  },
  "browser": {
    "mcp": true,
    "profile": "default",
    "headless": true
  },
  "mcpServers": {},
  "safety": { "allowCloud": false, "allowAutoPr": false }
}
