# Optional local overrides for dev (copied to .env — gitignored).
# Canonical runtime env for launchd/TUI: ~/.csagent/csagent.env (see deploy/csagent.env.example)
#
# Variant 1 (SQLite): set CSAGENT_HOME only — do NOT set CSAGENT_DATABASE_URL
# Variant 2 (Postgres): also set CSAGENT_DATABASE_URL (see README Install)
#
# CSAGENT_HOME=$HOME/.csagent
# CSAGENT_ROOT=$HOME/.csagent/csagent
# CSAGENT_DATABASE_URL=postgresql://csagent:csagent@127.0.0.1:5435/csagent
# CURSOR_API_KEY=
# TELEGRAM_BOT_TOKEN=
# CSAGENT_LOG=1              # stderr diagnostics for TUI/chat (rotation, runs, timing)
# CSAGENT_LOG_VERBOSE=1      # per-tool stream lines (very noisy)
